{
  "name": "@sittichai/bef-core",
  "version": "0.1.0",
  "description": "Framework-agnostic transport booking engine — TripProvider, BookingService, SeatLockService, MockProvider",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
