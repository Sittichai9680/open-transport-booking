  },
  "keywords": ["booking", "transport", "bus", "seat-map", "booking-engine"],
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
