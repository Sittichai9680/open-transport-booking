{
  "name": "@sittichai/bef-api",
  "version": "0.1.0",
  "description": "NestJS REST API for @sittichai/bef-core — transport booking endpoints",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["booking", "api", "transport", "nest", "bef"],
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "peerDependencies": {
    "@sittichai/bef-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
